# Modal
.modal/

# Claude Code session files — gitignore is per-FILE inside .claude/, so that
# team-shareable artifacts (commands/, skills/, settings.json) ARE tracked
# while personal/local state (settings.local.json, build logs, handoff notes)
# stays out.
.claude/settings.local.json
.claude/HANDOFF.md
.claude/build_state.json
.claude/checkpoint_log.md
.claude/daily_build_log.md
.claude/__pycache__/

# Personal toolkit skills — synced from product-toolkit, not project-specific
.claude/skills/
.claude/commands/anti-ai-ui.md
.claude/commands/frontend-component.md
.claude/commands/frontend-design.md
.claude/commands/mcp-builder.md
.claude/commands/new-component.md
.claude/commands/skill-creator.md
.claude/commands/theme-factory.md
.claude/commands/web-artifacts-builder.md

