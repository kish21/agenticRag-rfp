# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: openai | anthropic | openrouter | ollama | azure | modal
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_TEMPERATURE=0.1

# Azure OpenAI (only if LLM_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-01

# Anthropic (only if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenRouter (only if LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o

# Ollama (only if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:72b

# ── Observability ─────────────────────────────────────────────────────────────
# Options: langfuse | langsmith | stdout | none
OBSERVABILITY_PROVIDER=langfuse
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=agenticrag-rfp

# ── Embeddings ────────────────────────────────────────────────────────────────
# Options: openai | azure | local | modal
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL_LOCAL=BAAI/bge-large-en-v1.5

# ── Reranker ──────────────────────────────────────────────────────────────────
# Options: bge | cohere | colbert | none
RERANKER_PROVIDER=bge
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-english-v3.0

# ── Vector Store ──────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_PREFIX=rfp

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=platform_db
POSTGRES_USER=platform_user
POSTGRES_PASSWORD=changeme

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=changeme-must-be-32-chars-minimum-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
APP_API_KEY=changeme-internal-api-key

# ── Compute ───────────────────────────────────────────────────────────────────
# Options: modal | local_worker | aws_lambda | azure_functions | gcp_cloudrun
COMPUTE_PROVIDER=local_worker

# Modal (only if COMPUTE_PROVIDER=modal)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
MODAL_LLM_ENDPOINT=
MODAL_LLM_MODEL=Qwen/Qwen2.5-72B-Instruct-AWQ

# ── Notifications ─────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ── Platform Config ───────────────────────────────────────────────────────────
SSL_VERIFY=true
CONFIDENCE_THRESHOLD=0.75
MAX_RETRY_LIMIT=5
HARD_FLAG_BLOCKS_PIPELINE=true
RATE_LIMIT_REQUESTS_PER_MINUTE=50
LOG_ENABLE=true
